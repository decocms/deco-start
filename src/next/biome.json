{
  "$schema": "https://biomejs.dev/schemas/2.0/schema.json",
  "root": false,
  "extends": ["../../biome.json"],
  "linter": {
    "rules": {
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@tanstack/react-start": "Forbidden in next/**.",
              "@tanstack/react-start/server": "Forbidden in next/**.",
              "@tanstack/react-router": "Forbidden in next/**."
            }
          }
        }
      }
    }
  }
}
