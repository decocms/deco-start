  "exports": {
    ".": "./src/index.ts",
    "./cms": "./src/cms/index.ts",
    "./admin": "./src/admin/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./types": "./src/types/index.ts",
    "./compat": "./src/compat/index.ts",
    "./compat/vite": "./src/compat/vite.ts",
    "./compat/preact": "./src/compat/preact.ts",
    "./compat/preact-compat": "./src/compat/preact-compat.ts",
    "./compat/preact-hooks": "./src/compat/preact-hooks.ts",
    "./compat/signals": "./src/compat/signals.ts",
    "./compat/fresh-runtime": "./src/compat/fresh-runtime.ts",
    "./compat/deco": "./src/compat/deco.ts",
    "./compat/deco-hooks": "./src/compat/deco-hooks.ts",
    "./compat/deco-blocks": "./src/compat/deco-blocks.ts",
    "./compat/deco-o11y": "./src/compat/deco-o11y.ts",
